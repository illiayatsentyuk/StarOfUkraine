STAGED_FILES=$(git diff --name-only --cached)

# // Backend  \\
if echo "$STAGED_FILES" | grep -q '^apps/backend/'
then
  cd apps/backend && pnpm run lint && pnpm test && cd ../..
else
  echo "Skipping Backend (no changes)"
fi

# // Frontend  \\
if echo "$STAGED_FILES" | grep -q '^apps/frontend/';
then
  cd apps/frontend && pnpm run test:e2e && cd ../..
else
  echo "Skipping Frontend (no changes)"
fi
