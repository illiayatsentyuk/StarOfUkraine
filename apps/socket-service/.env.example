# Redis connection URL (used for both microservice transport and Socket.IO adapter)
REDIS_URL=redis://localhost:6379

# Port this service listens on for WebSocket connections
SOCKET_PORT=3001

# JWT secret — must match the backend's JWT_SECRET so socket auth tokens are accepted
JWT_SECRET=your_jwt_secret_here

# Node environment
NODE_ENV=development

# Allowed frontend origin for CORS (must be explicit — no wildcard when credentials are used)
CORS_ORIGIN=http://localhost:4040
