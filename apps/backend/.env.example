# Copy to `.env` and fill in real values. Never commit `.env`.

# Supabase / Postgres (use your project host, user, password, and DB name)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Generate strong random strings for production (e.g. openssl rand -base64 32)
JWT_SECRET="change-me"
AT_SECRET=
RT_SECRET="change-me"

JWT_EXPIRES_IN=1d
AT_EXPIRES_IN=15m
RT_EXPIRES_IN=7d

RESET_PASSWORD_SECRET="change-me"
RESET_PASSWORD_EXPIRES_IN=1h
EMAIL_RESET_PASSWORD_URL="http://localhost:4040/reset-password"

EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-password"

GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

PAGE_SIZE=10
PORT=3000
